    <Project Path="src/TUnit.AspNetCore.Core/TUnit.AspNetCore.Core.csproj" />
    <Project Path="src/TUnit.FsCheck/TUnit.FsCheck.csproj" />
    <Project Path="src/TUnit.Logging.Microsoft/TUnit.Logging.Microsoft.csproj" />
