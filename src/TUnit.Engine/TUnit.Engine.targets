<?xml version="1.0" encoding="utf-8"?>
<Project>

    <!-- LangVersion default moved to TUnit.Engine.props: a .targets default never wins against
         the SDK's target-framework LangVersion default (set during the .targets phase). See #6276/#6280. -->

    <ItemGroup Condition="'$(TUnitImplicitUsings)' == 'true'">
        <Using Include="TUnit.Core" />
    </ItemGroup>

    <PropertyGroup Condition="'$(TUnitReflectionScanner)' == 'true'">
        <TestingPlatformCommandLineArguments>$(TestingPlatformCommandLineArguments) --reflection</TestingPlatformCommandLineArguments>
    </PropertyGroup>

    <ItemGroup Condition="'$(TUnitReflectionScanner)' == 'true'">
        <AssemblyMetadata Include="TUnitReflectionScanner" Value="true" />
    </ItemGroup>

</Project>