<Project Sdk="Microsoft.NET.Sdk">

  <Import Project="..\..\eng\Library.props" />

  <PropertyGroup>
    <TargetFrameworks>net8.0;net9.0;net10.0</TargetFrameworks>
    <RootNamespace>TUnit.Aspire</RootNamespace>
  </PropertyGroup>

  <ItemGroup>
    <InternalsVisibleTo Include="TUnit.Aspire" />
    <InternalsVisibleTo Include="TUnit.Aspire.Tests" />
  </ItemGroup>

  <!-- Aspire is server-side only — remove browser platform support from Library.props -->
  <ItemGroup>
    <SupportedPlatform Remove="browser" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\TUnit.Core\TUnit.Core.csproj" />
    <ProjectReference Include="..\TUnit.OpenTelemetry\TUnit.OpenTelemetry.csproj" />
    <ProjectReference Include="..\TUnit.Core.SourceGenerator\TUnit.Core.SourceGenerator.csproj"
      OutputItemType="Analyzer" ReferenceOutputAssembly="false" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Aspire.Hosting.Testing" />
  </ItemGroup>

  <Import Project="..\..\eng\Library.targets" />
</Project>
