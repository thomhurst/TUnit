<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <EnableTUnitPolyfills>false</EnableTUnitPolyfills>
    <NoWarn>$(NoWarn);NU1510</NoWarn>
  </PropertyGroup>

  <Import Project="..\Library.props" />

  <ItemGroup>
    <InternalsVisibleTo Include="TUnit.UnitTests" />
    <InternalsVisibleTo Include="TUnit.AspNetCore" />
    <InternalsVisibleTo Include="TUnit.Engine.Tests" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="EnumerableAsyncProcessor" />
    <PackageReference Include="Microsoft.Testing.Extensions.TrxReport.Abstractions" />
    <PackageReference Include="Microsoft.Testing.Platform" />
  </ItemGroup>
  <ItemGroup>
    <PackageReference Include="System.Threading.Channels" />
  </ItemGroup>
  <ItemGroup>
    <!-- Direct reference: full props with test project configuration -->
    <None Include="TUnit.Engine.props">
      <Pack>true</Pack>
      <PackagePath>$(BuildPath)</PackagePath>
    </None>

    <!-- Transitive reference: empty props (test project settings must not flow transitively) -->
    <TfmSpecificPackageFile Include="TUnit.Engine.buildTransitive.props">
      <Pack>true</Pack>
      <PackagePath>$(BuildTransitivePath)TUnit.Engine.props</PackagePath>
    </TfmSpecificPackageFile>
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\TUnit.Core\TUnit.Core.csproj" />
  </ItemGroup>
  <ItemGroup>
    <PackageReference Include="Microsoft.Testing.Platform.MSBuild" />
  </ItemGroup>

  <Import Project="..\Library.targets" />

</Project>
