<Project Sdk="Microsoft.NET.Sdk">

    <Import Project="..\Library.props" />
    <Import Project="..\SourceGenerationDebug.props" />

    <ItemGroup>
        <ProjectReference Include="..\TUnit.Assertions\TUnit.Assertions.csproj" />

        <!-- Generator runs at Should.dll build time (baking built-in extensions) AND in
             consumer compilations (so users' own [AssertionExtension] classes get Should
             counterparts). The generator skips assertion classes whose Should{Name}Extensions
             already exists in a referenced assembly, preventing the CS0121 duplicate-definition
             ambiguity that would otherwise arise from re-emitting the baked extensions. -->
        <ProjectReference Include="..\TUnit.Assertions.Should.SourceGenerator\TUnit.Assertions.Should.SourceGenerator.csproj" OutputItemType="Analyzer" ReferenceOutputAssembly="false" />

        <None Include="$(MSBuildProjectDirectory)\..\TUnit.Assertions.Should.SourceGenerator\bin\$(Configuration)\netstandard2.0\TUnit.Assertions.Should.SourceGenerator.dll" Pack="true" PackagePath="analyzers/dotnet/cs" Visible="false" />
    </ItemGroup>

    <Import Project="..\Library.targets" />

</Project>
